# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/orbitkeeper?retryWrites=true&w=majority

# ── Google Gemini via Vertex AI ($1000 Google Cloud credits) ──────────────────
GOOGLE_CLOUD_PROJECT=orbitkeeper
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# ── Firebase Admin SDK (for authentication) ────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

# Email (Gmail SMTP) - optional for deadline reminders
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
