PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/orbitkeeper?retryWrites=true&w=majority

GOOGLE_CLOUD_PROJECT=orbitkeeper
GOOGLE_CLOUD_LOCATION=global
GOOGLE_CLOUD_MODEL=gemini-3.5-flash
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json


FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

CLIENT_URL=http://localhost:5173


EMAIL_USER=your_sender_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
